<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        app:titleTextColor="@color/colorPrimary"
        app:title="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/adView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Greeting -->
            <TextView
                android:id="@+id/greetingText"
                style="@style/TextTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/greeting_hi"
                android:textSize="36sp"
                android:layout_marginBottom="8dp"/>

            <!-- Streak Counter -->
            <androidx.cardview.widget.CardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <TextView
                        style="@style/TextLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/streak_label"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/streakCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="72sp"
                        android:textColor="@color/textPrimary"
                        android:fontFamily="sans-serif-black"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Completion Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    style="@style/TextLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/daily_completion"/>

                <TextView
                    android:id="@+id/completionPercentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="24sp"
                    android:textColor="@color/colorPrimary"
                    android:fontFamily="sans-serif-black"/>

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/colorPrimary"
                android:progressBackgroundTint="@color/zinc_900"
                android:layout_marginBottom="24dp"/>

            <!-- Workout Tasks -->
            <androidx.cardview.widget.CardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <CheckBox
                        android:id="@+id/warmupCheckbox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/warmup"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:buttonTint="@color/colorPrimary"
                        android:padding="12dp"/>

                    <CheckBox
                        android:id="@+id/cardioCheckbox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/cardio"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:buttonTint="@color/colorPrimary"
                        android:padding="12dp"/>

                    <CheckBox
                        android:id="@+id/stretchingCheckbox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/stretching"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:buttonTint="@color/colorPrimary"
                        android:padding="12dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Exercises -->
            <androidx.cardview.widget.CardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/exercises"
                        android:layout_marginBottom="12dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/exerciseRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Steps Input -->
            <androidx.cardview.widget.CardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/steps_protocol"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/stepsInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="8000"
                        android:inputType="number"
                        android:textSize="24sp"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textTertiary"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="@color/background"
                        android:fontFamily="monospace"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Save Button -->
            <Button
                android:id="@+id/saveButton"
                style="@style/ButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save_and_lock"
                android:padding="16dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>

    </ScrollView>

    <!-- AdMob Banner -->
    <com.google.android.gms.ads.AdView
        android:id="@+id/adView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:adSize="BANNER"
        app:adUnitId="ca-app-pub-9767918092469462/1963694912"/>

</androidx.constraintlayout.widget.ConstraintLayout>
