<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            style="@style/TextTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_title"
            android:textSize="48sp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            style="@style/TextBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_subtitle"
            android:textSize="18sp"
            android:layout_marginBottom="32dp"/>

        <!-- Name Input -->
        <TextView
            style="@style/TextLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/identity_label"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/nameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/enter_name"
            android:inputType="textPersonName"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textTertiary"
            android:backgroundTint="@color/colorPrimary"
            android:padding="16dp"/>

        <!-- Age, Height, Weight -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    style="@style/TextLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/age_label"/>

                <EditText
                    android:id="@+id/ageInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="25"
                    android:inputType="number"
                    android:textColor="@color/textPrimary"
                    android:backgroundTint="@color/colorPrimary"
                    android:padding="16dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    style="@style/TextLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/height_label"/>

                <EditText
                    android:id="@+id/heightInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="175"
                    android:inputType="number"
                    android:textColor="@color/textPrimary"
                    android:backgroundTint="@color/colorPrimary"
                    android:padding="16dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/weight_label"/>

                <EditText
                    android:id="@+id/weightInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="70"
                    android:inputType="number"
                    android:textColor="@color/textPrimary"
                    android:backgroundTint="@color/colorPrimary"
                    android:padding="16dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Activity Level -->
        <TextView
            style="@style/TextLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/activity_level"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/activityGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioActivityLow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/activity_low"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorPrimary"/>

            <RadioButton
                android:id="@+id/radioActivityMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/activity_medium"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorPrimary"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/radioActivityHigh"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/activity_high"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorPrimary"/>

        </RadioGroup>

        <!-- Training Mode -->
        <TextView
            style="@style/TextLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/training_mode"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/trainingGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorPrimary"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/radioGym"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/gym"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorPrimary"/>

        </RadioGroup>

        <!-- Goal -->
        <TextView
            style="@style/TextLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/your_goal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/goalGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioAthletic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/goal_athletic"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorPrimary"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/radioLean"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/goal_lean"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorPrimary"/>

            <RadioButton
                android:id="@+id/radioMuscular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/goal_muscular"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorPrimary"/>

            <RadioButton
                android:id="@+id/radioStrong"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/goal_strong"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorPrimary"/>

        </RadioGroup>

        <!-- Diet -->
        <TextView
            style="@style/TextLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diet_preference"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/dietGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioVeg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/vegetarian"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorPrimary"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/radioNonVeg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/non_vegetarian"
                android:textColor="@color/textPrimary"
                android:buttonTint="@color/colorPrimary"/>

        </RadioGroup>

        <!-- Submit Button -->
        <Button
            android:id="@+id/submitButton"
            style="@style/ButtonPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/start_protocol"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:padding="16dp"/>

    </LinearLayout>

</ScrollView>
